{
  "domains": [
    "api.anthropic.com",
    "api.github.com",
    "api.npmjs.org",
    "api.openai.com",
    "auth.openai.com",
    "chatgpt.com",
    "codeload.github.com",
    "generativelanguage.googleapis.com",
    "github.com",
    "objects.githubusercontent.com",
    "platform.claude.com",
    "raw.githubusercontent.com",
    "registry.npmjs.org",
    "sentry.io",
    "statsig.anthropic.com",
    "files.pythonhosted.org"
  ],
  "tokens": {
    "github": {
      "description": "Read-only GitHub API token for rate limit and public metadata",
      "allowAnonymous": true,
      "credentials": [
        {
          "host": "api.github.com",
          "header": "Authorization",
          "scheme": "bearer"
        },
        {
          "host": "raw.githubusercontent.com",
          "header": "Authorization",
          "scheme": "bearer"
        }
      ]
    },
    "gemini": {
      "description": "Gemini API key for native and OpenAI-compatible endpoints",
      "credentials": [
        {
          "host": "generativelanguage.googleapis.com",
          "header": "Authorization",
          "scheme": "bearer",
          "pathPrefix": "/v1beta/openai/"
        },
        {
          "host": "generativelanguage.googleapis.com",
          "header": "x-goog-api-key",
          "scheme": "raw"
        }
      ]
    }
  }
}
