{
  "name": "capshelf",
  "version": "0.4.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "bin": {
    "capshelf": "./dist/capshelf"
  },
  "scripts": {
    "dev": "bun run src/cli.ts",
    "serve": "bun run src/cli.ts serve",
    "web:dev": "cd web && bun run dev",
    "web:build": "cd web && bun install && bun run build",
    "test": "bun test",
    "coverage": "bun test --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "build": "mkdir -p dist && bun build --compile --minify --target=bun ./src/cli.ts --outfile=./dist/capshelf",
    "smoke": "make smoke"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ignore": "^7.0.5",
    "smol-toml": "^1.6.1",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
